{
  "expo": {
    "name": "Dune Weaver",
    "slug": "dune-weaver-mobile",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/dw-logo.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "assets/**",
      "assets/thr/**",
      "assets/previews/**"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.duneweaver",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Dune Weaver finds and connects to your sand table on the local network to control patterns.",
        "NSPhotoLibraryUsageDescription": "Dune Weaver lets you pick a photo to use as a custom app logo.",
        "NSBonjourServices": [
          "_http._tcp."
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.duneweaver",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1a1a1a",
        "foregroundImage": "./assets/dw-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true,
            "deploymentTarget": "16.4"
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d4ffdf8f-10b5-4ed9-a7b6-4cf486165c48"
      }
    },
    "owner": "duneweaver"
  }
}
